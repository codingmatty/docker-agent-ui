# Base URL of the Docker Agent API (not exposed to the browser).
# Must be a full URL with host and port. Use 127.0.0.1 (not 0.0.0.0) for local.
# Example: http://127.0.0.1:8080 when running "docker agent api agent.yaml --listen 127.0.0.1:8080"
DOCKER_AGENT_API_URL=http://127.0.0.1:8080

# Port for this UI server (serves the proxy + static frontend)
PORT=3000
